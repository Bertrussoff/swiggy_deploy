pipeline {
    agent any
    
    tools {
        jdk 'Temurin JDK 17'      // ← Change to the exact name you gave in Tools
        nodejs 'node23'           // ← Make sure this name matches Global Tool Configuration
    }
    
    environment {
        SCANNER_HOME = tool 'SonarQube Scanner'   // ← Exact name from Jenkins Tools
        IMAGE_NAME   = 'bertrussoff/swiggy'
        TAG          = 'latest'
    }
    
    stages {
        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }
        
        stage('Checkout from Git') {
            steps {
                git branch: 'main', 
                    url: 'https://github.com/Bertrussoff/swiggy_deploy.git'
                // Add credentialsId: 'your-github-cred' if repo is private
            }
        }
        
        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('sonar-server') {   // ← Make sure this name matches your SonarQube server config
                    sh '''
                        $SCANNER_HOME/bin/sonar-scanner \
                        -Dsonar.projectName=Swiggy \
                        -Dsonar.projectKey=Swiggy \
                        -Dsonar.sources=.
                    '''
                }
            }
        }
        
        stage('Quality Gate') {
            steps {
                script {
                    timeout(time: 10, unit: 'MINUTES') {   // Safety timeout
                        waitForQualityGate abortPipeline: true, credentialsId: 'Sonar-token'
                    }
                }
            }
        }
        
        stage('Install Dependencies') {
            steps {
                sh 'npm install'
            }
        }
        
        stage('OWASP Dependency Check') {
            steps {
                dependencyCheck additionalArguments: '--scan ./ --disableYarnAudit --disableNodeAudit', 
                               odcInstallation: 'DP-Check'
                dependencyCheckPublisher pattern: '**/dependency-check-report.xml'
            }
        }
        
        stage('TRIVY Filesystem Scan') {
            steps {
                sh 'trivy fs . --format table -o trivyfs.txt'
            }
        }
        
        stage('Docker Build & Push') {
            steps {
                script {
                    docker.withRegistry('', 'docker-creds') {   // Better modern syntax
                        sh """
                            docker build -t ${IMAGE_NAME}:${TAG} .
                            docker push ${IMAGE_NAME}:${TAG}
                        """
                    }
                }
            }
        }
        
        stage('TRIVY Image Scan') {
            steps {
                sh "trivy image ${IMAGE_NAME}:${TAG} --format table -o trivy.txt"
            }
        }
        
        stage('Deploy to Container') {
            steps {
                script {
                    // Stop and remove old container if exists
                    sh '''
                        docker stop swiggy || true
                        docker rm swiggy || true
                    '''
                    sh "docker run -d --name swiggy -p 3000:3000 ${IMAGE_NAME}:${TAG}"
                }
            }
        }
    }
    
    post {
        always {
            echo 'Pipeline finished'
            // Optional: archive reports
            archiveArtifacts artifacts: 'trivyfs.txt, trivy.txt', allowEmptyArchive: true
        }
        success {
            echo '✅ Pipeline completed successfully!'
        }
        failure {
            echo '❌ Pipeline failed'
        }
    }
}
